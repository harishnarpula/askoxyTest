{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/wc-proxy/staticblitz/:path*",
      "destination": "https://t.staticblitz.com/:path*"
    },
    {
      "source": "/wc-proxy/wasm/:path*",
      "destination": "https://w-corp-staticblitz.com/:path*"
    }
  ]
}
